source 'https://rubygems.org'

# Lock the github-pages gem to a specific version. 
# This version will pull in compatible versions of its dependencies.
gem 'github-pages', group: :jekyll_plugins

group :jekyll_plugins do
  gem 'jekyll-feed'
  gem 'jekyll-sitemap'
  gem 'jemoji'
  gem 'webrick', '~> 1.8' # Required for local Jekyll server on newer Ruby versions
end
